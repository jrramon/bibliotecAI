<%# Global search widget in the app header. The input lives inside a
    turbo-frame so results update in place without a full page
    reload. `search_controller.js` handles ⌘K focus, debounced input
    submission, and arrow-key navigation through hits. %>
<div class="header-search" data-controller="search" data-action="keydown.window@window->search#globalShortcut">
  <%= form_with url: search_path, method: :get,
                data: {turbo_frame: "search-results", search_target: "form"},
                html: {class: "header-search-form", role: "search"} do |f| %>
    <%= f.search_field :q,
                       value: params[:q],
                       autocomplete: "off",
                       placeholder: "Buscar libros, miembros, notas…",
                       aria: {label: "Buscar"},
                       data: {search_target: "input",
                              action: "input->search#debouncedSubmit keydown->search#navigate focus->search#open"} %>
    <span class="header-search-kbd" aria-hidden="true"><kbd>⌘</kbd><kbd>K</kbd></span>
  <% end %>

  <div class="header-search-popover" data-search-target="popover" hidden>
    <turbo-frame id="search-results" target="_top">
      <p class="search-hint">Escribe para buscar en tus bibliotecas.</p>
    </turbo-frame>
  </div>
</div>
