<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title) || "BibliotecAI · 函" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Pre-apply saved palette/layout from localStorage before any paint so
        the page doesn't flash the default theme on reload. %>
    <script>
      (function () {
        try {
          var raw = localStorage.getItem("bibliotecai:tweaks");
          if (!raw) return;
          var s = JSON.parse(raw);
          if (s && s.theme) document.documentElement.setAttribute("data-theme", s.theme);
          if (s && s.layout) document.documentElement.setAttribute("data-shelf-layout", s.layout);
        } catch (_) { /* ignore */ }
      })();
    </script>
  </head>

  <body>
    <div class="app <%= "app--guest" unless user_signed_in? %>">
      <% if user_signed_in? %>
        <aside class="sidebar" aria-label="Navegación">
          <%= render "shared/brand" %>
          <nav class="nav-section" aria-label="Principal">
            <span class="nav-label">Biblioteca</span>
            <%= link_to libraries_path, class: "nav-item #{"active" if controller_name == "libraries" && action_name == "index"}" do %>
              <span>Mis bibliotecas</span>
              <span class="count"><%= current_user.libraries.count %></span>
            <% end %>
            <%= link_to wishlist_path, class: "nav-item #{"active" if controller_name == "wishlist_items"}" do %>
              <span>Lista de deseos</span>
              <span class="count"><%= current_user.wishlist_items.count %></span>
            <% end %>
          </nav>
          <% if @library&.persisted? %>
            <%= render "shared/members_widget", library: @library %>
            <%= render "shared/tags_rail", library: @library, scope: @library.books %>
          <% end %>
        </aside>
      <% end %>

      <header class="header">
        <% unless user_signed_in? %>
          <%= render "shared/brand" %>
        <% end %>
        <% if user_signed_in? %>
          <%= render "shared/header_search" %>
        <% end %>
        <div class="header-actions">
          <% if user_signed_in? %>
            <%= link_to edit_user_registration_path, class: "header-profile-link", aria: {label: "Editar mi perfil"} do %>
              <%= avatar_for(current_user, size: :sm) %>
              <span class="user-email"><%= current_user.display_name %></span>
            <% end %>
            <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "btn btn-ghost", data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to "Iniciar sesión", new_user_session_path, class: "btn btn-ghost" %>
            <%= link_to "Registrarse", new_user_registration_path, class: "btn btn-primary" %>
          <% end %>
        </div>
      </header>

      <main class="main">
        <% if notice %><p class="flash notice" role="status"><%= notice %></p><% end %>
        <% if alert %><p class="flash alert" role="alert"><%= alert %></p><% end %>
        <%= yield %>
      </main>
    </div>

    <% if user_signed_in? %>
      <%= render "shared/tweaks_panel" %>
    <% end %>
  </body>
</html>
