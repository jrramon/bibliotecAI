<%= turbo_frame_tag "book_candidates" do %>
  <% if candidates.empty? %>
    <p class="empty-mini">Sin resultados para «<%= query %>». Prueba con otro query.</p>
  <% else %>
    <ul class="candidate-list">
      <% candidates.each do |c| %>
        <li class="candidate">
          <div class="thumb">
            <% if c.thumbnail_url.present? %>
              <%= image_tag c.thumbnail_url, alt: c.title, loading: "lazy" %>
            <% else %>
              <div class="thumb-placeholder" aria-hidden="true">函</div>
            <% end %>
          </div>
          <div class="info">
            <h4><%= c.title %></h4>
            <% if c.authors.present? %>
              <p class="author"><%= c.author %></p>
            <% end %>
            <dl class="candidate-meta">
              <% if c.publisher.present? %>
                <dt>Editorial</dt><dd><%= c.publisher %></dd>
              <% end %>
              <% if c.year.present? %>
                <dt>Año</dt><dd><%= c.year %></dd>
              <% end %>
              <% if c.isbn.present? %>
                <dt>ISBN</dt><dd><code><%= c.isbn %></code></dd>
              <% end %>
              <% if c.page_count %>
                <dt>Páginas</dt><dd><%= c.page_count %></dd>
              <% end %>
            </dl>
            <% if c.description.present? %>
              <p class="excerpt"><%= truncate(c.description, length: 220) %></p>
            <% end %>
          </div>
          <div class="actions">
            <%= button_to apply_candidate_library_book_path(book.library, book), method: :post, class: "btn btn-primary btn-small" do %>
              <%= hidden_field_tag "candidate[title]", c.title %>
              <%= hidden_field_tag "candidate[author]", c.author %>
              <%= hidden_field_tag "candidate[isbn]", c.isbn %>
              <%= hidden_field_tag "candidate[publisher]", c.publisher %>
              <%= hidden_field_tag "candidate[published_date]", c.published_date %>
              <%= hidden_field_tag "candidate[thumbnail_url]", c.thumbnail_url %>
              Aplicar este
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
