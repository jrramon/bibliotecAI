<%= turbo_frame_tag "book_candidates" do %>
  <% has_prior_data = book.synopsis.present? || book.publisher.present? || book.published_year.present? ||
                      book.page_count.present? || book.language.present? || book.cover_image.attached? ||
                      book.google_books_id.present? %>
  <% confirm_msg = has_prior_data ? "Este libro ya tiene datos cargados. ¿Quieres sobrescribirlos con los de este candidato?" : nil %>
  <% if candidates.empty? %>
    <p class="empty-mini">Sin resultados para «<%= query %>». Prueba con otro query.</p>
  <% else %>
    <ul class="candidate-list">
      <% candidates.each do |c| %>
        <li class="candidate">
          <div class="thumb">
            <% if c.thumbnail_url.present? %>
              <%= image_tag c.thumbnail_url, alt: c.title, loading: "lazy" %>
            <% else %>
              <div class="thumb-placeholder" aria-hidden="true">函</div>
            <% end %>
          </div>
          <div class="info">
            <h4><%= c.title %></h4>
            <% if c.authors.present? %>
              <p class="author"><%= c.author %></p>
            <% end %>
            <dl class="candidate-meta">
              <% if c.publisher.present? %>
                <dt>Editorial</dt><dd><%= c.publisher %></dd>
              <% end %>
              <% if c.year.present? %>
                <dt>Año</dt><dd><%= c.year %></dd>
              <% end %>
              <% if c.isbn.present? %>
                <dt>ISBN</dt><dd><code><%= c.isbn %></code></dd>
              <% end %>
              <% if c.page_count %>
                <dt>Páginas</dt><dd><%= c.page_count %></dd>
              <% end %>
            </dl>
            <% if c.description.present? %>
              <p class="excerpt"><%= truncate(c.description, length: 220) %></p>
            <% end %>
          </div>
          <div class="actions">
            <%= button_to apply_candidate_library_book_path(book.library, book),
                          method: :post,
                          class: "btn btn-primary btn-small",
                          form: {data: {turbo_frame: "_top", turbo_confirm: confirm_msg}.compact} do %>
              <%= hidden_field_tag "candidate[title]", c.title %>
              <%= hidden_field_tag "candidate[subtitle]", c.subtitle %>
              <%= hidden_field_tag "candidate[author]", c.author %>
              <%= hidden_field_tag "candidate[isbn]", c.isbn %>
              <%= hidden_field_tag "candidate[publisher]", c.publisher %>
              <%= hidden_field_tag "candidate[published_date]", c.published_date %>
              <%= hidden_field_tag "candidate[published_year]", c.published_year %>
              <%= hidden_field_tag "candidate[page_count]", c.page_count %>
              <%= hidden_field_tag "candidate[language]", c.language %>
              <%= hidden_field_tag "candidate[synopsis]", c.description %>
              <%= hidden_field_tag "candidate[google_books_id]", c.volume_id %>
              <%= hidden_field_tag "candidate[thumbnail_url]", c.thumbnail_url %>
              Aplicar este
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
