<section class="page book-show">
  <%= link_to library_path(@library), class: "back-link back-link-top" do %>
    ← Volver a <%= @library.name %>
  <% end %>

  <div class="detail">
    <div class="detail-cover-wrap">
      <% if @book.cover_image.attached? %>
        <%= image_tag @book.cover_image.variant(:hero), class: "detail-cover-image", alt: @book.title %>
      <% else %>
        <div class="detail-cover">
          <div class="dc-title"><%= @book.title %></div>
          <% if @book.author.present? %>
            <div class="dc-author"><%= @book.author %></div>
          <% end %>
          <span class="dc-stamp" aria-hidden="true">函</span>
        </div>
        <%= button_to "Buscar portada",
                      fetch_cover_library_book_path(@library, @book),
                      method: :post,
                      class: "btn btn-ghost btn-find-cover" %>
      <% end %>
    </div>

    <div class="detail-info">
      <p class="breadcrumb">
        <%= link_to @library.name, @library %>
      </p>
      <h1><%= @book.title %></h1>
      <% if @book.subtitle.present? %>
        <p class="subtitle"><%= @book.subtitle %></p>
      <% end %>
      <% if @book.author.present? %>
        <p class="by">por <%= @book.author %></p>
      <% end %>

      <% if @book.synopsis.present? %>
        <div class="description expandable" data-controller="expandable">
          <div class="expandable-body" data-expandable-target="body">
            <span class="dropcap"><%= @book.synopsis %></span>
          </div>
          <button type="button"
                  class="expandable-toggle"
                  data-action="expandable#toggle"
                  data-expandable-target="toggle">[más]</button>
        </div>
      <% end %>

      <% my_note = @book.note_for(current_user) %>
      <div class="personal-notes-wrap" data-controller="modal">
        <% if my_note.persisted? && my_note.body.present? %>
          <div class="personal-notes">
            <h3>Mi nota <span class="private-tag">solo tú</span></h3>
            <p><%= simple_format my_note.body %></p>
            <button type="button" class="btn-link notes-edit"
                    data-action="modal#open"
                    aria-label="Editar mi nota personal">Editar nota</button>
          </div>
        <% else %>
          <button type="button" class="btn btn-ghost notes-add"
                  data-action="modal#open">＋ Añadir mi nota personal</button>
        <% end %>

        <dialog class="modal-dialog" data-modal-target="dialog" data-action="click->modal#backdropClick">
          <div class="modal-card">
            <header>
              <h3>Mi nota personal</h3>
              <button type="button" class="modal-close"
                      data-action="modal#close"
                      aria-label="Cerrar">✕</button>
            </header>
            <p class="modal-hint">Solo tú verás esto. Los demás miembros de la biblioteca no tienen acceso a tus notas personales.</p>
            <%= form_with url: note_library_book_path(@library, @book),
                          method: :patch,
                          scope: :user_book_note,
                          html: {class: "modal-form"} do |f| %>
              <%= f.text_area :body, rows: 8, autofocus: true,
                              value: my_note.body,
                              placeholder: "Tus apuntes, recuerdos, citas favoritas…" %>
              <div class="modal-actions">
                <button type="button" class="btn btn-ghost" data-action="modal#close">Cancelar</button>
                <%= f.submit "Guardar nota", class: "btn btn-primary" %>
              </div>
            <% end %>
          </div>
        </dialog>
      </div>

      <% if @book.genres.any? || @book.cdu.present? %>
        <div class="chips">
          <% if @book.cdu.present? %>
            <span class="chip chip-cdu">CDU <%= @book.cdu %></span>
          <% end %>
          <% @book.genres.each do |g| %>
            <span class="chip chip-genre"><%= g %></span>
          <% end %>
        </div>
      <% end %>

      <dl class="bib">
        <% if @book.publisher.present? %>
          <dt>Editorial</dt><dd><%= @book.publisher %></dd>
        <% end %>
        <% if @book.published_year.present? %>
          <dt>Año</dt><dd><%= @book.published_year %></dd>
        <% end %>
        <% if @book.page_count.present? %>
          <dt>Páginas</dt><dd><%= @book.page_count %></dd>
        <% end %>
        <% if @book.language.present? %>
          <dt>Idioma</dt><dd><%= @book.language.upcase %></dd>
        <% end %>
        <% if @book.isbn.present? %>
          <dt>ISBN</dt><dd><code><%= @book.isbn %></code></dd>
        <% end %>
        <% if @book.cdu.present? %>
          <dt>CDU</dt><dd><code><%= @book.cdu %></code></dd>
        <% end %>
        <% if @book.genres.any? %>
          <dt>Géneros</dt><dd><%= @book.genres.join(" · ") %></dd>
        <% end %>
        <% if @book.google_books_id.present? %>
          <dt>Google Books</dt>
          <dd><%= link_to "Ver ficha", "https://books.google.com/books?id=#{@book.google_books_id}", target: "_blank", rel: "noopener" %></dd>
        <% end %>
        <% if @book.goodreads_url.present? %>
          <dt>Goodreads</dt>
          <dd><%= link_to @book.goodreads_url, @book.goodreads_url, target: "_blank", rel: "noopener" %></dd>
        <% end %>
        <dt>Añadido por</dt><dd><%= @book.added_by_user.email %></dd>
        <dt>Añadido el</dt><dd><%= l(@book.created_at, format: :long) %></dd>
      </dl>

      <% status = @book.reading_status_for(current_user) %>
      <div class="action-row">
        <% if status.nil? %>
          <%= button_to start_reading_library_book_path(@library, @book), method: :post, class: "btn btn-primary" do %>
            📖 Empezar a leer
          <% end %>
        <% elsif status.reading? %>
          <%= button_to finish_reading_library_book_path(@library, @book), method: :post, class: "btn btn-primary" do %>
            ✓ Marcar como leído
          <% end %>
          <%= button_to stop_reading_library_book_path(@library, @book), method: :delete, class: "btn btn-ghost" do %>
            Dejar de leer
          <% end %>
        <% elsif status.read? %>
          <span class="chip chip-moss">Leído <%= l(status.finished_at.to_date, format: :short) if status.finished_at %></span>
          <%= button_to start_reading_library_book_path(@library, @book), method: :post, class: "btn btn-ghost" do %>
            Releer
          <% end %>
        <% end %>
        <%= link_to "Editar", edit_library_book_path(@library, @book), class: "btn btn-ghost" %>
        <%= button_to "Eliminar", library_book_path(@library, @book),
                      method: :delete,
                      class: "btn btn-ghost",
                      form: {data: {turbo_confirm: "¿Eliminar este libro?"}} %>
      </div>
    </div>
  </div>

  <section class="comments" aria-labelledby="comments-heading">
    <%= turbo_stream_from [@book, :comments] %>

    <h3 id="comments-heading">
      Notas y comentarios
      <span class="count" data-book-comments-count><%= @book.comments.count %></span>
    </h3>

    <div class="thread" id="<%= dom_id(@book, :comments) %>">
      <% @book.comments.recent.each do |comment| %>
        <%= render "comments/comment", comment: comment, viewer: current_user %>
      <% end %>
    </div>

    <div id="<%= dom_id(@book, :comment_form) %>">
      <%= render "comments/form", book: @book %>
    </div>
  </section>
</section>
