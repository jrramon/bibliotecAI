<%# Full-page add-book form: live spine preview + uploaded-cover
    thumbnail on the left, minimal form on the right (title, author,
    stamp, colour). Full detail is set later on the edit page.

    Wrapped in a #new-book-form div so the cover-identification Turbo
    Stream broadcasts can swap this partial in place with a pre-filled
    copy (once Claude finishes reading the uploaded cover) or with the
    "Analizando portada…" state while that runs.

    Expects locals:
      library       — Library
      book          — Book (new or with errors)
      cover_photo   — optional CoverPhoto (Claude-identified; its image
                      will be attached to the book on create). %>
<% cover_photo = local_assigns[:cover_photo] %>
<div id="new-book-form">
  <div class="new-book-card book-preview-layout" data-controller="book-preview">
    <% if cover_photo&.completed? %>
      <p class="cover-identified-hint">
        📷 Datos identificados desde la portada. Revísalos y edita lo que haga falta.
      </p>
    <% end %>

    <div class="book-preview-grid">
      <aside class="spine-preview-panel" aria-hidden="true">
        <div class="spine spine-slot-<%= book.spine_palette || 0 %> spine-preview"
             data-book-preview-target="spine">
          <span class="spine-mark" data-book-preview-target="stampOut">
            <%= book.stamp.presence || "函" %>
          </span>
          <span class="spine-title" data-book-preview-target="titleOut">
            <%= book.title.presence || "Título" %>
          </span>
          <span class="spine-author" data-book-preview-target="authorOut">
            <%= book.author.to_s.split(/\s+/).last.presence || "Autor" %>
          </span>
        </div>
        <% if cover_photo&.image&.attached? %>
          <figure class="uploaded-cover-thumb">
            <%= image_tag cover_photo.image.variant(:thumb), alt: "Portada subida" %>
          </figure>
        <% end %>
      </aside>

      <div class="book-preview-form" data-controller="cover-upload">
        <%# Upload form sits as a sibling to the book form — HTML forbids
            nested <form> elements. The Stimulus `cover-upload` controller
            bridges the two: the button inside the book form triggers the
            file input in this form, which auto-submits on change. %>
        <%= form_with url: library_cover_photos_path(library),
                      method: :post,
                      multipart: true,
                      html: {class: "cover-upload-form"} do |g| %>
          <%= g.file_field :image,
                           accept: "image/jpeg,image/png,image/webp,image/heic",
                           data: {cover_upload_target: "input",
                                  action: "change->cover-upload#submit"},
                           class: "visually-hidden" %>
        <% end %>

        <%= form_with model: [library, book], html: {class: "modal-form", novalidate: true} do |f| %>
          <% if book.errors.any? %>
            <ul class="form-errors">
              <% book.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          <% end %>

          <% if cover_photo %>
            <%= hidden_field_tag "book[cover_photo_id]", cover_photo.id %>
          <% end %>

          <label class="field">
            <span class="field-label">Título <em>*</em></span>
            <%= f.text_field :title,
                             required: true,
                             autofocus: true,
                             autocomplete: "off",
                             data: {action: "input->book-preview#updateTitle"} %>
          </label>

          <label class="field">
            <span class="field-label">Autor</span>
            <%= f.text_field :author,
                             autocomplete: "off",
                             data: {action: "input->book-preview#updateAuthor"} %>
          </label>

          <label class="field">
            <span class="field-label">Sello <em>opcional</em></span>
            <%= f.text_field :stamp,
                             maxlength: 2,
                             autocomplete: "off",
                             placeholder: "函",
                             data: {action: "input->book-preview#updateStamp"} %>
          </label>

          <fieldset class="swatches">
            <legend>Color del lomo</legend>
            <div class="swatch-grid">
              <label class="swatch swatch-auto <%= "is-selected" if book.spine_palette.nil? %>">
                <%= f.radio_button :spine_palette, "",
                                   checked: book.spine_palette.nil?,
                                   data: {action: "change->book-preview#updateSlot"} %>
                <span class="swatch-label" aria-label="Aleatorio">⤫</span>
              </label>
              <% 10.times do |slot| %>
                <label class="swatch spine-slot-<%= slot %> <%= "is-selected" if book.spine_palette == slot %>">
                  <%= f.radio_button :spine_palette, slot,
                                     checked: book.spine_palette == slot,
                                     data: {action: "change->book-preview#updateSlot"} %>
                  <span class="swatch-check" aria-hidden="true">✓</span>
                </label>
              <% end %>
            </div>
          </fieldset>

          <div class="form-actions form-actions--split">
            <button type="button" class="btn btn-ghost btn-small"
                    data-action="cover-upload#pick">📷 Identificar desde foto</button>
            <div class="spacer"></div>
            <%= link_to "Cancelar", library_path(library), class: "btn btn-ghost" %>
            <%= f.submit "＋ Añadir a la estantería", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
