<%# Renders while the host poller runs Claude on the uploaded cover
    photo. Subscribes to broadcasts targeted at [cover_photo, :status]
    — on completion the job broadcasts a replace of #new-book-form
    with books/new_form (pre-filled), or with
    cover_photos/identification_failed on error. Expects locals:
    `library`, `cover_photo`, `book`. %>
<div id="new-book-form">
  <div class="new-book-card cover-analyzing">
    <%= turbo_stream_from [cover_photo, :status] %>

    <div class="cover-analyzing-body">
      <figure class="cover-upload-preview">
        <%= image_tag cover_photo.image.variant(:thumb), alt: "Portada subida" %>
      </figure>
      <div class="cover-analyzing-copy">
        <div class="spinner-sumi" aria-hidden="true"></div>
        <p class="analyzing-title">Claude está leyendo la portada</p>
        <p class="analyzing-sub">Normalmente tarda 5–15 segundos.</p>
        <%= link_to "Cancelar", library_path(library), class: "btn btn-ghost btn-small" %>
      </div>
    </div>
  </div>
</div>
