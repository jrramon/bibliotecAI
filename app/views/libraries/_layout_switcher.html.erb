<div class="layout-switcher" data-controller="layout-switcher" role="group" aria-label="Vista de libros">
  <button type="button"
          class="layout-icon"
          data-layout-switcher-target="button"
          data-value="spine"
          data-action="layout-switcher#set"
          aria-label="Ver como lomos"
          title="Lomos">
    <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false">
      <rect x="3"  y="3" width="2" height="14" rx="0.5" fill="currentColor"/>
      <rect x="7"  y="5" width="2" height="12" rx="0.5" fill="currentColor"/>
      <rect x="11" y="3" width="2" height="14" rx="0.5" fill="currentColor"/>
      <rect x="15" y="6" width="2" height="11" rx="0.5" fill="currentColor"/>
    </svg>
  </button>

  <button type="button"
          class="layout-icon"
          data-layout-switcher-target="button"
          data-value="grid"
          data-action="layout-switcher#set"
          aria-label="Ver como cuadrícula"
          title="Cuadrícula">
    <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false">
      <rect x="3"  y="3"  width="6" height="6" rx="1" fill="currentColor"/>
      <rect x="11" y="3"  width="6" height="6" rx="1" fill="currentColor"/>
      <rect x="3"  y="11" width="6" height="6" rx="1" fill="currentColor"/>
      <rect x="11" y="11" width="6" height="6" rx="1" fill="currentColor"/>
    </svg>
  </button>

  <button type="button"
          class="layout-icon"
          data-layout-switcher-target="button"
          data-value="list"
          data-action="layout-switcher#set"
          aria-label="Ver como lista"
          title="Lista">
    <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false">
      <rect x="3" y="4"  width="14" height="2" rx="1" fill="currentColor"/>
      <rect x="3" y="9"  width="14" height="2" rx="1" fill="currentColor"/>
      <rect x="3" y="14" width="14" height="2" rx="1" fill="currentColor"/>
    </svg>
  </button>
</div>
