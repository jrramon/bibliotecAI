<section class="page libraries">
  <header class="page-head">
    <div class="title-group">
      <h1 class="page-title">Mis <span class="accent">bibliotecas</span></h1>
      <p class="sub">Un estante por cada grupo de lectores.</p>
    </div>
    <%= link_to "＋ Nueva biblioteca", new_library_path, class: "btn btn-seal" %>
  </header>

  <% if @libraries.any? %>
    <ul class="library-list">
      <% @libraries.each do |library| %>
        <li>
          <%= link_to library.name, library_path(library) %>
          <span class="meta"><%= pluralize(library.users.count, "miembro", plural: "miembros") %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="empty-state">Aún no tienes bibliotecas. Crea la primera para empezar.</p>
  <% end %>
</section>
