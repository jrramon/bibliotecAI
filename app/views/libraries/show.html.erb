<section class="page library-show">
  <header class="page-head">
    <div class="title-group">
      <p class="eyebrow">Biblioteca</p>
      <h1 class="page-title"><%= @library.name %></h1>
      <% if @library.description.present? %>
        <p class="sub description"><%= @library.description %></p>
      <% end %>
    </div>
    <div class="header-ctas">
      <%= link_to "＋ Subir foto de estantería", new_library_shelf_photo_path(@library), class: "btn btn-seal" %>
      <%= render "books/new_modal", library: @library %>
      <%= link_to "Configuración", settings_library_path(@library), class: "btn btn-ghost" %>
    </div>
  </header>

  <dl class="stat-row">
    <div>
      <dt>Libros</dt>
      <dd><%= @library.books.count %></dd>
    </div>
    <div>
      <dt>Miembros</dt>
      <dd><%= @library.users.count %></dd>
    </div>
    <div>
      <dt>Fotos de estantería</dt>
      <dd><%= @library.shelf_photos.count %></dd>
    </div>
  </dl>

  <%= form_with url: library_path(@library), method: :get, local: true, class: "book-search" do |f| %>
    <%= f.search_field :q,
                       value: @query,
                       placeholder: "Buscar por título, sinopsis o tus notas",
                       autocomplete: "off",
                       aria: {label: "Buscar libros"} %>
    <% if @query.present? %>
      <span class="book-search-count">
        <%= pluralize(@books.size, "resultado", plural: "resultados") %> para «<%= @query %>»
      </span>
      <%= link_to "Limpiar", library_path(@library), class: "book-search-clear" %>
    <% end %>
  <% end %>

  <% if @reading_books&.any? %>
    <section class="reading-now">
      <h2 class="section-title">Leyendo ahora <span class="count">(<%= @reading_books.size %>)</span></h2>
      <div class="shelf reading-now-shelf">
        <div class="bookend" aria-hidden="true"></div>
        <% @reading_books.each do |book| %>
          <%= render "books/spine", book: book, library: @library %>
        <% end %>
        <div class="bookend" aria-hidden="true"></div>
      </div>
    </section>
  <% end %>

  <% if @books.any? %>
    <%# The three layouts (spines / grid / list) all render at once; CSS
        shows exactly one based on <html data-shelf-layout>, so switching
        from the Tweaks panel is instant — no page reload needed. %>
    <section class="books-layout books-layout--spine" aria-label="Estantería (lomos)">
      <div class="shelf">
        <div class="bookend" aria-hidden="true"></div>
        <% @books.each do |book| %>
          <%= render "books/spine", book: book, library: @library %>
        <% end %>
        <div class="bookend" aria-hidden="true"></div>
      </div>
    </section>

    <section class="books-layout books-layout--grid" aria-label="Estantería (cuadrícula)">
      <ul class="book-grid">
        <% @books.each do |book| %>
          <%= render "books/card", book: book, library: @library %>
        <% end %>
      </ul>
    </section>

    <section class="books-layout books-layout--list" aria-label="Estantería (lista)">
      <div class="book-list">
        <div class="book-list-head" aria-hidden="true">
          <span></span>
          <span>Título / autor</span>
          <span>Género</span>
          <span>Añadido</span>
        </div>
        <% @books.each do |book| %>
          <%= render "books/row", book: book, library: @library %>
        <% end %>
      </div>
    </section>
  <% elsif @query.present? %>
    <div class="empty-state hero-empty">
      <span class="kanji" aria-hidden="true">索</span>
      <h2>Sin resultados</h2>
      <p>Ningún libro coincide con «<%= @query %>» en el título, sinopsis o tus notas personales.</p>
      <p class="cta">
        <%= link_to "Ver todos los libros", library_path(@library), class: "btn btn-ghost" %>
      </p>
    </div>
  <% else %>
    <div class="empty-state hero-empty">
      <span class="kanji" aria-hidden="true">本</span>
      <h2>Aún no hay libros</h2>
      <p>Sube una foto de tu estantería para identificar libros automáticamente, o añade uno a mano.</p>
      <p class="cta">
        <%= link_to "Subir foto", new_library_shelf_photo_path(@library), class: "btn btn-primary" %>
        <%= link_to "Añadir libro", new_library_book_path(@library), class: "btn btn-ghost" %>
      </p>
    </div>
  <% end %>

  <% shelf_photos = @library.shelf_photos.recent.limit(8) %>
  <% if shelf_photos.any? %>
    <section class="shelf-photos-section">
      <h2 class="section-title">Fotos de estantería</h2>
      <ul class="shelf-photo-strip">
        <% shelf_photos.each do |photo| %>
          <li>
            <%= link_to [@library, photo], class: "shelf-photo-thumb status-#{photo.status}" do %>
              <%= image_tag photo.image.variant(:card), alt: "Foto de estantería subida por #{photo.uploaded_by_user.email}" %>
              <span class="badge status-<%= photo.status %>"><%= photo.status.humanize %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <%= link_to "← Volver a mis bibliotecas", libraries_path, class: "back-link" %>
</section>
