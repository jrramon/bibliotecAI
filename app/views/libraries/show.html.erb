<section class="page library-show">
  <header class="page-head">
    <div class="title-group">
      <h1 class="page-title"><%= @library.name %></h1>
      <p class="sub">
        <%= pluralize(@books.size, "volumen", plural: "volúmenes") %>
        · <%= pluralize(@library.users.count, "miembro", plural: "miembros") %>
      </p>
    </div>
    <div class="header-ctas">
      <%= link_to "＋ Añadir libro", new_library_book_path(@library), class: "btn btn-seal" %>
      <%= link_to "Configuración", settings_library_path(@library), class: "btn btn-ghost" %>
    </div>
  </header>

  <% if @library.description.present? %>
    <p class="description"><%= @library.description %></p>
  <% end %>

  <% if @books.any? %>
    <ul class="book-grid">
      <% @books.each do |book| %>
        <li class="book-card">
          <%= link_to [@library, book], class: "book-card-link" do %>
            <% if book.cover_image.attached? %>
              <%= image_tag book.cover_image.variant(:card), class: "book-cover-image", alt: book.title %>
            <% else %>
              <div class="book-cover placeholder">
                <span class="cov-title"><%= book.title %></span>
                <% if book.author.present? %>
                  <span class="cov-author"><%= book.author %></span>
                <% end %>
                <span class="cov-stamp" aria-hidden="true">函</span>
              </div>
            <% end %>
          <% end %>
          <div class="book-meta">
            <span class="bm-title"><%= book.title %></span>
            <% if book.author.present? %>
              <span class="bm-author"><%= book.author %></span>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="empty-state">Aún no hay libros en esta biblioteca. Añade el primero.</p>
  <% end %>

  <%= link_to "← Volver a mis bibliotecas", libraries_path, class: "back-link" %>
</section>
