<section class="page library-settings">
  <header class="page-head">
    <div class="title-group">
      <h1 class="page-title"><%= @library.name %> <span class="accent">· configuración</span></h1>
      <p class="sub">Miembros e invitaciones de esta biblioteca.</p>
    </div>
    <%= link_to "← Volver a los libros", library_path(@library), class: "btn btn-ghost" %>
  </header>

  <% if @library.description.present? %>
    <p class="description"><%= @library.description %></p>
  <% end %>

  <section class="members-section">
    <h2 class="section-title">Miembros</h2>
    <ul class="member-list">
      <% @library.memberships.includes(:user).order(:created_at).each do |membership| %>
        <li class="member-row">
          <span class="avatar"><%= membership.user.email.first.upcase %></span>
          <div class="info">
            <span class="nm"><%= membership.user.email %></span>
            <span class="sub"><%= membership.role.humanize %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </section>

  <% if @is_owner %>
    <section class="invite-section">
      <h2 class="section-title">Invitar a otro lector</h2>
      <%= simple_form_for [@library, Invitation.new], html: {class: "invite-form"} do |f| %>
        <div class="form-inputs">
          <%= f.input :email, label: "Correo electrónico del invitado", required: true, input_html: {type: "email", autocomplete: "off"} %>
        </div>
        <div class="form-actions">
          <%= f.button :submit, "Enviar invitación" %>
        </div>
      <% end %>

      <% unaccepted = @library.invitations.unaccepted %>
      <% if unaccepted.any? %>
        <div class="pending-invites">
          <h3>Invitaciones pendientes</h3>
          <ul>
            <% unaccepted.each do |inv| %>
              <li class="<%= "is-expired" if inv.expired? %>">
                <span class="email"><%= inv.email %></span>
                <% if inv.expired? %>
                  <span class="chip chip-warn">caducada el <%= l(inv.expires_at.to_date, format: :short) %></span>
                <% else %>
                  <span class="expires">expira <%= l(inv.expires_at.to_date, format: :short) %></span>
                <% end %>
                <div class="invite-actions">
                  <%= button_to "Reenviar", resend_library_invitation_path(@library, inv),
                                method: :post,
                                class: "btn btn-ghost btn-small" %>
                  <%= button_to "Cancelar", library_invitation_path(@library, inv),
                                method: :delete,
                                class: "btn btn-ghost btn-small btn-danger",
                                form: {data: {turbo_confirm: "¿Cancelar la invitación a #{inv.email}?"}} %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </section>
  <% end %>
</section>
