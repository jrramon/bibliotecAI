<section class="page shelf-photo-new">
  <header class="page-head">
    <div class="title-group">
      <h1 class="page-title">Subir <span class="accent">fotos de estantería</span></h1>
      <p class="sub">Sube una o varias fotos de tus libros. Claude las irá identificando una a una en segundo plano.</p>
    </div>
  </header>

  <div class="card">
    <%= form_with url: library_shelf_photos_path(@library), method: :post,
                  multipart: true, html: {class: "shelf-photo-upload"} do %>
      <div class="form-inputs">
        <label class="field">
          <span class="field-label">Imágenes de la estantería</span>
          <%= file_field_tag "shelf_photo[images][]",
                             multiple: true,
                             accept: "image/jpeg,image/png,image/webp,image/heic",
                             required: true %>
          <small>JPEG, PNG, WebP o HEIC. Puedes seleccionar varias a la vez.</small>
        </label>
      </div>

      <div class="form-actions">
        <%= submit_tag "Subir e identificar", class: "btn btn-primary" %>
        <%= link_to "Cancelar", library_path(@library), class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</section>
