<section class="page shelf-photo-new">
  <header class="page-head">
    <div class="title-group">
      <h1 class="page-title">Subir <span class="accent">foto de estantería</span></h1>
      <p class="sub">Sube una foto de tus libros y Claude intentará identificarlos automáticamente.</p>
    </div>
  </header>

  <div class="card">
    <%= simple_form_for [@library, @shelf_photo], html: {multipart: true} do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :image,
                    label: "Imagen de la estantería",
                    as: :file,
                    required: true,
                    input_html: {accept: "image/jpeg,image/png,image/webp,image/heic"},
                    hint: "JPEG, PNG, WebP o HEIC" %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Subir e identificar" %>
        <%= link_to "Cancelar", library_path(@library) %>
      </div>
    <% end %>
  </div>
</section>
