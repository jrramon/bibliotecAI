<%# Public registration is closed. Random visitors see the waitlist
    form; invitees (detected via a pending Invitation matching the
    prefilled email) see the real Devise registration form so they can
    actually complete their account. %>
<% content_for :title, @invitee ? "Crear cuenta" : "Lista de espera" %>
<% content_for :description, @invitee ?
     "Crea tu cuenta de BibliotecAI para unirte a la biblioteca a la que te han invitado." :
     "BibliotecAI está abriendo poco a poco, por invitación. Apúntate a la lista de espera y te avisamos en cuanto haya hueco." %>

<% if @invitee %>
  <%= render "invitee_form", resource: resource, resource_name: resource_name %>
<% else %>
  <%= render "waitlist" %>
<% end %>
