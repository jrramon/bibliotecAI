<%# Devise registration form for someone who landed here via an
    Invitation link (InvitationsController#show redirects with ?email=…).
    The controller's #create still re-checks that the email matches a
    pending invitation, so this form can never be used to bypass the
    invite gate even if a curious user manually visits the URL with a
    crafted email param. %>
<section class="page waitlist-page">
  <div class="waitlist-card">
    <p class="eyebrow">Te han invitado</p>
    <h1 class="waitlist-title">Crea tu cuenta.</h1>
    <p class="waitlist-lede">
      Vas a unirte a una biblioteca compartida. Solo necesitamos un
      nombre y una contraseña — el email ya lo trajiste con la invitación.
    </p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
                 html: {class: "waitlist-form"}) do |f| %>
      <% if resource.errors.any? %>
        <ul class="form-errors">
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      <% end %>

      <label class="field">
        <span class="field-label">Nombre</span>
        <%= f.text_field :name, autocomplete: "name", placeholder: "Cómo te ven los demás" %>
      </label>

      <label class="field">
        <span class="field-label">Email</span>
        <%= f.email_field :email, autocomplete: "email", required: true %>
      </label>

      <label class="field">
        <span class="field-label">Contraseña</span>
        <%= f.password_field :password, autocomplete: "new-password", required: true %>
        <% if @minimum_password_length %>
          <small>Mínimo <%= @minimum_password_length %> caracteres.</small>
        <% end %>
      </label>

      <label class="field">
        <span class="field-label">Confirmar contraseña</span>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true %>
      </label>

      <div class="waitlist-submit">
        <%= f.submit "Sign up", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</section>
