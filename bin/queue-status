#!/usr/bin/env bash
# Quick status of shelf photos + the poller process. Run from the project root.
set -euo pipefail

HOST="${DATABASE_HOST:-localhost}"
PORT="${DATABASE_PORT:-5433}"
USER="${DATABASE_USERNAME:-rails_dev}"
DB="${POSTGRES_DB:-bibliotecai_development}"
export PGPASSWORD="${DATABASE_PASSWORD:-aqwe123}"

echo "=== Shelf photos (last 10) ==="
psql -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" -c "
  SELECT id,
         CASE status WHEN 0 THEN 'pending' WHEN 1 THEN 'processing' WHEN 2 THEN 'completed' WHEN 3 THEN 'failed' END AS status,
         library_id,
         coalesce(substring(error_message,1,40),'') AS err,
         to_char(created_at,'YYYY-MM-DD HH24:MI') AS created
  FROM shelf_photos
  ORDER BY id DESC
  LIMIT 10;"

echo "=== Cover photos (last 10) ==="
psql -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" -c "
  SELECT id,
         CASE status WHEN 0 THEN 'pending' WHEN 1 THEN 'processing' WHEN 2 THEN 'completed' WHEN 3 THEN 'failed' END AS status,
         library_id,
         coalesce(substring(error_message,1,40),'') AS err,
         to_char(created_at,'YYYY-MM-DD HH24:MI') AS created
  FROM cover_photos
  ORDER BY id DESC
  LIMIT 10;"

echo "=== Telegram messages (last 10) ==="
psql -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" -c "
  SELECT id,
         CASE status WHEN 0 THEN 'pending' WHEN 1 THEN 'processing' WHEN 2 THEN 'completed' WHEN 3 THEN 'failed' END AS status,
         user_id,
         chat_id,
         coalesce(substring(text,1,30),'') AS text,
         to_char(created_at,'YYYY-MM-DD HH24:MI') AS created
  FROM telegram_messages
  ORDER BY id DESC
  LIMIT 10;"

echo "=== Host worker process ==="
PID_FILE="tmp/photo-worker.pid"
if [ -f "$PID_FILE" ]; then
  WORKER_PID=$(cat "$PID_FILE")
  if kill -0 "$WORKER_PID" 2>/dev/null; then
    echo "  alive  pid=$WORKER_PID"
    ps -p "$WORKER_PID" -o pid,etime,command | tail -n +2
  else
    echo "  stale PID file (pid=$WORKER_PID not running)"
    echo "  start with: bin/shelf-photo-poller"
  fi
else
  echo "  (no worker running on host — start with bin/shelf-photo-poller)"
fi
