#!/usr/bin/env bash
# Thin wrapper around bin/claude-worker.rb. Kept under the old name so
# existing muscle memory still works. The actual logic lives in the Ruby
# file — edit it there, not here. Re-run this wrapper to pick up changes.
#
# Usage:
#   bin/shelf-photo-poller           # default INTERVAL=5s
#   INTERVAL=15 bin/shelf-photo-poller
set -euo pipefail

if ! command -v claude >/dev/null 2>&1 && [ -z "${CLAUDE_BIN:-}" ]; then
  echo "error: claude not on PATH and CLAUDE_BIN unset" >&2
  exit 1
fi

# Load env files so secrets like TELEGRAM_BOT_TOKEN reach the host worker.
# Docker compose loads them for the web container automatically; this
# wrapper runs outside Docker, so we have to do it ourselves. We try both
# .env.development and .env (in that order — the second wins on overlap)
# to match whichever convention the project happens to use.
for ENV_FILE in .env.development .env; do
  if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
done

export DATABASE_HOST="${DATABASE_HOST:-localhost}"
export DATABASE_PORT="${DATABASE_PORT:-5433}"
export DATABASE_USERNAME="${DATABASE_USERNAME:-rails_dev}"
export DATABASE_PASSWORD="${DATABASE_PASSWORD:-aqwe123}"
export CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude)}"
export RAILS_ENV="${RAILS_ENV:-development}"

echo "[wrapper] starting claude-worker  DB=$DATABASE_HOST:$DATABASE_PORT  CLAUDE_BIN=$CLAUDE_BIN"
exec bundle exec bin/rails runner bin/claude-worker.rb
