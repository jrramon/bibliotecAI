# Rails
RAILS_ENV=production
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here

# Public hostname(s) this deployment serves. Comma-separated if more than
# one (apex + www, several subdomains). The first one is treated as the
# canonical and used for mailer links + SMTP HELO. REQUIRED — Rails will
# fail to boot in production without it.
APP_HOSTS=biblio.example.org

# Database (PostgreSQL on host machine)
DATABASE_HOST=host.docker.internal
DATABASE_USERNAME=bibliotecai
BIBLIOTECAI_DATABASE_PASSWORD=your_database_password_here

# Email (Brevo SMTP)
BREVO_USERNAME=your_brevo_username
BREVO_PASSWORD=your_brevo_password

# Background jobs (SolidQueue runs inside Puma)
SOLID_QUEUE_IN_PUMA=1

# Telegram bot (optional). Without these, the bot endpoints reject
# every request and the rest of the app keeps working.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Where the host claude CLI reaches the MCP HTTP endpoint. The
# claude-worker container is on the same Docker network as `web`, so
# the service-name URL works without going through the public proxy.
MCP_ENDPOINT_URL=http://web/mcp

# Optional
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5
