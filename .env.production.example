# Rails
RAILS_ENV=production
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here

# Database (PostgreSQL on host machine)
DATABASE_HOST=host.docker.internal
DATABASE_USERNAME=bibliotecai
BIBLIOTECAI_DATABASE_PASSWORD=your_database_password_here

# Email (Brevo SMTP)
BREVO_USERNAME=your_brevo_username
BREVO_PASSWORD=your_brevo_password

# Background jobs (SolidQueue runs inside Puma)
SOLID_QUEUE_IN_PUMA=1

# Optional
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5
