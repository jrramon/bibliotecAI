# Copy to .env (docker-compose loads it automatically) and adjust.
# This file documents environment variables used in development.

DATABASE_USERNAME=rails_dev
DATABASE_PASSWORD=aqwe123
DATABASE_HOST=db
DATABASE_PORT=5432

# Path to the Claude Code CLI binary on the HOST running the Solid Queue worker.
# Leave as "claude" if it's on $PATH, otherwise set absolute path.
# Example on macOS cmux install: /Applications/cmux.app/Contents/Resources/bin/claude
CLAUDE_BIN=claude

# Google Books API key (optional). Without it, requests share the public
# per-IP quota (~1000/day) and return 429 once exhausted. With a key the
# default quota is much higher (free tier).
# Create at https://console.cloud.google.com/apis/credentials after enabling
# the "Books API" in your project.
GOOGLE_BOOKS_API_KEY=
